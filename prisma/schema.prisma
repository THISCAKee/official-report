// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  //url = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  HEAD
  EXECUTIVE
  PERSONNEL
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  HEAD_APPROVED
  HEAD_REJECTED
  EXECUTIVE_APPROVED
  EXECUTIVE_REJECTED
}

enum TripPurpose {
  MEETING
  TRAINING_SEMINAR
  STUDY_VISIT
  OTHER
}

enum TransportMode {
  AIRPLANE
  TRAIN
  BUS
  PRIVATE_CAR
  GOVERNMENT_CAR
  OTHER
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  username        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  departmentId Int?
  isActive     Boolean  @default(true)

  department   Department? @relation(fields: [departmentId], references: [id])
  reports      TripReport[] @relation("UserReports")
  reviewed     TripReport[] @relation("ReviewedReports")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String
  users     User[]
  reports   TripReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TripReport {
  id              Int          @id @default(autoincrement())
  title           String
  objective       String       @db.Text
  location        String
  province        String?
  startDate       DateTime
  endDate         DateTime
  budget          Decimal?     @db.Decimal(10, 2)
  requestDate     DateTime     @default(now())
  requesterPosition String?
  companions      String?      @db.Text
  purposeType     TripPurpose  @default(MEETING)
  purposeOther    String?
  transportMode   TransportMode?
  vehicleRegistration String?
  driverName      String?
  distanceKm      Decimal?     @db.Decimal(10, 2)
  allowanceDays   Int?
  allowanceAmount Decimal?     @db.Decimal(10, 2)
  accommodationDays Int?
  accommodationAmount Decimal? @db.Decimal(10, 2)
  transportAmount Decimal?     @db.Decimal(10, 2)
  driverCompensationAmount Decimal? @db.Decimal(10, 2)
  registrationFeeAmount Decimal? @db.Decimal(10, 2)
  otherExpenseDetail String?   @db.Text
  otherExpenseAmount Decimal?  @db.Decimal(10, 2)
  totalBudgetText String?
  budgetSource    String?
  budgetCategory  String?
  budgetProjectName String?
  result          String?      @db.Text
  problem         String?      @db.Text
  suggestion      String?      @db.Text
  status          ReportStatus @default(DRAFT)

  userId          Int
  departmentId    Int?
  reviewedById    Int?

  user            User         @relation("UserReports", fields: [userId], references: [id])
  department      Department?  @relation(fields: [departmentId], references: [id])
  reviewedBy      User?        @relation("ReviewedReports", fields: [reviewedById], references: [id])

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}
